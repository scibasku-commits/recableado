---
// ChatDrawer — Recableado blog chatbot
// Giora's personal AI assistant for the blog
import type { Lang } from '../i18n/languages';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const ariaToggle = t('chat.aria.toggle') as string;
const ariaClose = t('chat.aria.close') as string;
const ariaMic = t('chat.aria.mic') as string;
const ariaSend = t('chat.aria.send') as string;
const greeting = t('chat.drawer.greeting') as string;
const placeholder = t('chat.drawer.placeholder') as string;
const listening = t('chat.drawer.listening') as string;
const speechLang = lang === 'en' ? 'en-US' : 'es-ES';
const pillFive = t('chat.drawer.pill.fiveBrains') as string;
const pillGin = t('chat.drawer.pill.ginTonic') as string;
const pillStack = t('chat.drawer.pill.stack') as string;
const pillNoCode = t('chat.drawer.pill.noCoding') as string;
const msgFive = t('chat.msg.fiveBrains') as string;
const msgGin = t('chat.msg.ginTonic') as string;
const msgStack = t('chat.msg.stack') as string;
const msgNoCode = t('chat.msg.noCoding') as string;
const errConnection = t('chat.error.connection') as string;
const errGeneric = t('chat.error.generic') as string;
const fallback = t('chat.fallback') as string;
const signature = t('chat.drawer.signature') as string;
---

<!-- Trigger button — fixed bottom right -->
<button id="chat-toggle" class="cd-toggle" aria-label={ariaToggle}>
  <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
  </svg>
</button>

<!-- Backdrop -->
<div id="chat-backdrop" class="cd-backdrop hidden"></div>

<!-- Chat panel -->
<div id="chat-panel" class="cd-panel translate-y-full opacity-0 pointer-events-none">
  <div class="cd-card">

    <!-- Header -->
    <div class="cd-header">
      <div class="cd-header-left">
        <div class="cd-avatar">G</div>
        <div>
          <p class="cd-name">Giora</p>
          <p class="cd-sub">Recableado</p>
        </div>
      </div>
      <button id="chat-close" class="cd-close" aria-label={ariaClose}>
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Messages area -->
    <div id="chat-messages" class="cd-messages">
      <div class="chat-msg-assistant">
        <div class="cd-bubble cd-bubble-bot">{greeting}</div>
      </div>

      <!-- Suggestion chips -->
      <div id="chat-suggestions" class="cd-chips">
        <button class="chat-chip" data-msg={msgFive}>{pillFive}</button>
        <button class="chat-chip" data-msg={msgGin}>{pillGin}</button>
        <button class="chat-chip" data-msg={msgStack}>{pillStack}</button>
        <button class="chat-chip" data-msg={msgNoCode}>{pillNoCode}</button>
      </div>
    </div>

    <!-- Input area -->
    <div class="cd-input-wrap">
      <form id="chat-form" class="cd-form">
        <textarea
          id="chat-input"
          rows="1"
          placeholder={placeholder}
          class="cd-textarea"
          maxlength="500"
        ></textarea>
        <button type="button" id="chat-mic" class="cd-icon-btn cd-mic hidden" aria-label={ariaMic}>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-14 0m7 7v4m-3 0h6m-3-11V3a3 3 0 00-6 0v8a3 3 0 006 0z" />
          </svg>
        </button>
        <button type="submit" id="chat-send" class="cd-icon-btn cd-send" aria-label={ariaSend} disabled>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
          </svg>
        </button>
      </form>
      <p class="cd-signature">{signature}</p>
    </div>
  </div>
</div>

<style>
  /* ChatDrawer — vanilla CSS (no Tailwind in repo) */
  .cd-toggle {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 55;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    background: #1a365d;
    color: #fff;
    box-shadow: 0 8px 24px rgba(26, 54, 93, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 2px solid rgba(232, 130, 92, 0.3);
    transition: background 0.2s, box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }
  .cd-toggle:hover {
    background: #e8825c;
    border-color: #e8825c;
    box-shadow: 0 12px 30px rgba(26, 54, 93, 0.35);
    transform: translateY(-1px);
  }

  .cd-backdrop {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .cd-panel {
    position: fixed;
    z-index: 70;
    bottom: 0;
    right: 0;
    width: 100%;
    transition: transform 0.3s ease-out, opacity 0.3s ease-out;
  }
  @media (min-width: 640px) {
    .cd-panel {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 400px;
      max-width: calc(100vw - 2rem);
    }
  }

  .cd-card {
    background: #fffaf0;
    box-shadow: 0 20px 50px rgba(26, 54, 93, 0.25);
    display: flex;
    flex-direction: column;
    border: 1px solid #eee8dd;
    max-height: min(550px, 80vh);
  }
  @media (min-width: 640px) {
    .cd-card {
      border-radius: 1rem;
      overflow: hidden;
    }
  }

  .cd-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.25rem;
    background: #1a365d;
    flex-shrink: 0;
  }
  .cd-header-left { display: flex; align-items: center; gap: 0.75rem; }
  .cd-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: #e8825c;
    color: #fff;
    font-weight: 700;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bricolage Grotesque', sans-serif;
  }
  .cd-name {
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.1;
    margin: 0;
    font-family: 'Bricolage Grotesque', sans-serif;
  }
  .cd-sub {
    color: #e8825c;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.1;
    margin: 0.15rem 0 0;
  }
  .cd-close {
    color: rgba(255, 255, 255, 0.7);
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s;
  }
  .cd-close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .cd-messages {
    flex-grow: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 120px;
  }

  .cd-bubble {
    padding: 0.7rem 1rem;
    max-width: 85%;
    font-size: 0.88rem;
    line-height: 1.55;
    color: #2d3748;
    font-family: 'Lora', Georgia, serif;
    border-radius: 1rem;
  }
  .cd-bubble-bot {
    background: rgba(26, 54, 93, 0.06);
    border-top-left-radius: 0.4rem;
  }
  .chat-msg-assistant { display: flex; }

  .cd-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 0.25rem;
  }

  .cd-input-wrap {
    flex-shrink: 0;
    border-top: 1px solid #eee8dd;
    padding: 0.75rem 1rem 0.85rem;
    background: rgba(255, 255, 255, 0.65);
  }
  @media (min-width: 640px) {
    .cd-input-wrap {
      border-bottom-left-radius: 1rem;
      border-bottom-right-radius: 1rem;
    }
  }

  .cd-form {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
  }
  .cd-textarea {
    flex-grow: 1;
    background: #fffaf0;
    border: 1px solid #eee8dd;
    border-radius: 0.75rem;
    padding: 0.6rem 0.9rem;
    font-size: 0.88rem;
    color: #2d3748;
    resize: none;
    outline: none;
    transition: border-color 0.2s;
    font-family: 'Lora', Georgia, serif;
    line-height: 1.5;
    max-height: 100px;
  }
  .cd-textarea::placeholder { color: rgba(113, 128, 150, 0.6); }
  .cd-textarea:focus { border-color: rgba(232, 130, 92, 0.55); }

  .cd-icon-btn {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, opacity 0.2s, transform 0.15s;
  }
  .cd-mic {
    background: transparent;
    border-color: #eee8dd;
    color: #1a365d;
  }
  .cd-mic:hover { background: rgba(26, 54, 93, 0.05); }
  .cd-send {
    background: #e8825c;
    color: #fff;
    border: 0;
  }
  .cd-send:hover { background: #d4714d; }
  .cd-send:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    background: #e8825c;
  }
  .cd-signature {
    font-size: 0.6rem;
    color: rgba(113, 128, 150, 0.55);
    margin: 0.5rem 0 0;
    text-align: center;
    font-family: 'Bricolage Grotesque', sans-serif;
    letter-spacing: 0.02em;
  }

  /* Reusable utility classes used by the JS to toggle visibility/animation */
  .hidden { display: none !important; }
  .translate-y-full { transform: translateY(100%); }
  .translate-y-0 { transform: translateY(0); }
  .opacity-0 { opacity: 0; }
  .opacity-100 { opacity: 1; }
  .pointer-events-none { pointer-events: none; }

  .chat-chip {
    background: transparent;
    border: 1px solid rgba(232, 130, 92, 0.3);
    color: #e8825c;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Bricolage Grotesque', sans-serif;
    white-space: nowrap;
  }
  .chat-chip:hover {
    background: rgba(232, 130, 92, 0.08);
    border-color: rgba(232, 130, 92, 0.6);
  }

  #chat-mic.recording {
    background: rgba(239, 68, 68, 0.1) !important;
    border-color: rgba(239, 68, 68, 0.5) !important;
    color: #ef4444 !important;
    animation: mic-pulse 1.5s infinite ease-in-out;
  }
  @keyframes mic-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3); }
    50% { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); }
  }

  .typing-dot {
    animation: typing 1.4s infinite ease-in-out;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typing {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }
</style>

<script define:vars={{ lang, errConnection, errGeneric, fallback, placeholder, listening, speechLang }}>
  const toggle = document.getElementById('chat-toggle');
  const panel = document.getElementById('chat-panel');
  const closeBtn = document.getElementById('chat-close');
  const backdrop = document.getElementById('chat-backdrop');
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const sendBtn = document.getElementById('chat-send');
  const messagesEl = document.getElementById('chat-messages');
  const suggestionsEl = document.getElementById('chat-suggestions');

  let isOpen = false;
  let messages = [];
  let isLoading = false;

  function openChat() {
    isOpen = true;
    backdrop.classList.remove('hidden');
    toggle.style.display = 'none';
    panel.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
    panel.classList.add('translate-y-0', 'opacity-100');
    setTimeout(() => input.focus(), 100);
  }

  function closeChat() {
    isOpen = false;
    backdrop.classList.add('hidden');
    panel.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
    panel.classList.remove('translate-y-0', 'opacity-100');
    setTimeout(() => { toggle.style.display = ''; }, 200);
  }

  toggle.addEventListener('click', openChat);
  closeBtn.addEventListener('click', closeChat);
  backdrop.addEventListener('click', closeChat);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) closeChat(); });

  input.addEventListener('input', () => {
    sendBtn.disabled = input.value.trim().length === 0 || isLoading;
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 100) + 'px';
  });

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (!sendBtn.disabled) form.dispatchEvent(new Event('submit'));
    }
  });

  suggestionsEl.addEventListener('click', (e) => {
    const chip = e.target.closest('.chat-chip');
    if (chip) sendMessage(chip.dataset.msg || chip.textContent || '');
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text || isLoading) return;
    sendMessage(text);
  });

  async function sendMessage(text) {
    suggestionsEl.style.display = 'none';
    messages.push({ role: 'user', content: text });
    appendMessage('user', text);

    input.value = '';
    input.style.height = 'auto';
    sendBtn.disabled = true;
    isLoading = true;

    const typingEl = showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages, page_context: window.location.pathname, lang }),
      });

      const data = await res.json();
      typingEl.remove();

      if (data.error) {
        appendMessage('assistant', errGeneric);
        return;
      }

      const reply = data.content?.[0]?.text || data.response || fallback;
      messages.push({ role: 'assistant', content: reply });
      appendMessage('assistant', reply);
    } catch {
      typingEl.remove();
      appendMessage('assistant', errConnection);
    } finally {
      isLoading = false;
      sendBtn.disabled = input.value.trim().length === 0;
    }
  }

  function appendMessage(role, text) {
    const wrapper = document.createElement('div');
    wrapper.className = role === 'user' ? 'flex justify-end' : 'chat-msg-assistant';

    const bubble = document.createElement('div');
    if (role === 'user') {
      bubble.className = 'bg-[#e8825c]/10 border border-[#e8825c]/20 rounded-2xl rounded-tr-md px-4 py-2.5 max-w-[85%] text-[0.88rem] leading-relaxed text-[#2d3748]';
    } else {
      bubble.className = 'bg-[#1a365d]/5 rounded-2xl rounded-tl-md px-4 py-2.5 max-w-[85%] text-[0.88rem] leading-relaxed text-[#2d3748]';
    }
    bubble.style.fontFamily = "'Lora',Georgia,serif";

    var formatted = text
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/\*\*([^*]+)\*\*/g, '<strong style="color:#1a365d">$1</strong>')
      .replace(/\n\n/g, '<br><br>')
      .replace(/\n/g, '<br>');
    bubble.innerHTML = formatted;
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function showTyping(): HTMLElement {
    const wrapper = document.createElement('div');
    wrapper.className = 'chat-msg-assistant';
    wrapper.innerHTML = `
      <div class="bg-[#1a365d]/5 rounded-2xl rounded-tl-md px-4 py-3 flex gap-1.5 items-center">
        <span class="typing-dot w-2 h-2 bg-[#e8825c] rounded-full inline-block"></span>
        <span class="typing-dot w-2 h-2 bg-[#e8825c] rounded-full inline-block"></span>
        <span class="typing-dot w-2 h-2 bg-[#e8825c] rounded-full inline-block"></span>
      </div>`;
    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return wrapper;
  }

  // --- Voice input (Web Speech API) ---
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  const micBtn = document.getElementById('chat-mic');
  const micIcon = '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-14 0m7 7v4m-3 0h6m-3-11V3a3 3 0 00-6 0v8a3 3 0 006 0z" /></svg>';
  const stopIcon = '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><rect x="6" y="6" width="12" height="12" rx="2" /></svg>';

  if (SpeechRecognition && micBtn) {
    micBtn.classList.remove('hidden');
    const recognition = new SpeechRecognition();
    recognition.lang = speechLang; recognition.interimResults = true; recognition.continuous = false;
    let isRecording = false; let finalTranscript = '';

    micBtn.addEventListener('click', () => {
      if (isRecording) { recognition.stop(); } else { finalTranscript = ''; recognition.start(); }
    });
    recognition.addEventListener('start', () => { isRecording = true; micBtn.classList.add('recording'); micBtn.innerHTML = stopIcon; input.placeholder = listening; });
    recognition.addEventListener('result', (e) => { let interim = ''; finalTranscript = ''; for (let i = 0; i < e.results.length; i++) { e.results[i].isFinal ? finalTranscript += e.results[i][0].transcript : interim += e.results[i][0].transcript; } input.value = finalTranscript || interim; input.dispatchEvent(new Event('input')); });
    recognition.addEventListener('end', () => { isRecording = false; micBtn.classList.remove('recording'); micBtn.innerHTML = micIcon; input.placeholder = placeholder; if (finalTranscript.trim()) { input.value = finalTranscript.trim(); input.dispatchEvent(new Event('input')); input.focus(); } });
    recognition.addEventListener('error', () => { isRecording = false; micBtn.classList.remove('recording'); micBtn.innerHTML = micIcon; input.placeholder = placeholder; });
  }
</script>
