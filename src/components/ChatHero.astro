---
// ChatHero — Embedded prominent chatbot on homepage
// Positioned between hero and milestone cards, dark background
---

<section class="chat-hero-section">
  <div class="chat-hero-inner">
    <!-- Intro text -->
    <div class="chat-hero-intro">
      <div class="chat-hero-badge">
        <span class="chat-hero-dot"></span>
        <span>Pregúntale a Giora</span>
      </div>
      <p class="chat-hero-tagline">De gin tonics a prompts. 5 IAs, 0 programadores, 1 agencia de viajes.<br/>Pregúntame cómo.</p>
    </div>

    <!-- Chat container -->
    <div class="chat-hero-box">
      <!-- Messages -->
      <div id="hero-chat-messages" class="chat-hero-messages">
        <div class="hcm-bot">
          <div class="hcm-avatar">G</div>
          <div class="hcm-bubble">Buenas. 72 años, 5 IAs y un negocio que se gestiona casi solo. No programo — pido. Y funciona. Dispara.</div>
        </div>
      </div>

      <!-- Pills -->
      <div id="hero-chat-pills" class="chat-hero-pills">
        <button class="hc-pill" data-msg="¿Qué son los Cinco Cerebros y cómo los usas?">🧠 Los 5 cerebros</button>
        <button class="hc-pill" data-msg="¿De verdad construiste todo sin saber programar? ¿Cómo?">🔧 Sin programar</button>
        <button class="hc-pill" data-msg="¿Tienes agentes de IA que trabajan solos mientras duermes?">🤖 Agentes autónomos</button>
        <button class="hc-pill" data-msg="¿Cómo pasaste de no saber nada de IA a construir todo esto en 6 meses?">🍸 De gin tonic a prompt</button>
      </div>

      <!-- Input -->
      <form id="hero-chat-form" class="chat-hero-input">
        <textarea
          id="hero-chat-input"
          rows="1"
          placeholder="Escríbeme algo..."
          maxlength="500"
        ></textarea>
        <button type="button" id="hero-chat-mic" class="hc-mic-btn hidden" aria-label="Dictar por voz">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-14 0m7 7v4m-3 0h6m-3-11V3a3 3 0 00-6 0v8a3 3 0 006 0z" />
          </svg>
        </button>
        <button type="submit" id="hero-chat-send" class="hc-send-btn" disabled aria-label="Enviar">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .chat-hero-section {
    background: linear-gradient(180deg, #f0e6d6 0%, #faf6ef 100%);
    padding: 48px 28px 80px;
    position: relative;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
  }
  .chat-hero-section::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 40px;
    background: var(--bg, #fffaf0);
    clip-path: ellipse(55% 100% at 50% 100%);
  }
  .chat-hero-section::before {
    content: '';
    position: absolute;
    top: -1px; left: 0; right: 0;
    height: 40px;
    background: #0a0a1a;
    clip-path: ellipse(55% 100% at 50% 0%);
  }

  .chat-hero-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .chat-hero-intro {
    text-align: center;
    margin-bottom: 24px;
    padding-top: 16px;
  }

  .chat-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 999px;
    background: rgba(232, 130, 92, 0.1);
    border: 1px solid rgba(232, 130, 92, 0.3);
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--naranja, #e8825c);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .chat-hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--naranja, #e8825c);
    animation: dot-pulse 2s infinite ease-in-out;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .chat-hero-tagline {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.15rem;
    color: var(--text, #2d3748);
    line-height: 1.6;
    margin: 0;
  }

  .chat-hero-box {
    background: white;
    border: 1px solid var(--border, #eee8dd);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(26, 54, 93, 0.08);
  }

  .chat-hero-messages {
    padding: 20px 20px 12px;
    max-height: 300px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hcm-bot, .hcm-user {
    display: flex;
    gap: 10px;
    max-width: 100%;
  }

  .hcm-user {
    flex-direction: row-reverse;
  }

  .hcm-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--naranja, #e8825c), var(--azul-medio, #2b6cb0));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: white;
    flex-shrink: 0;
  }

  .hcm-bubble {
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 1rem;
    line-height: 1.6;
    max-width: 85%;
  }

  .hcm-bot .hcm-bubble {
    background: #f7f3ec;
    color: var(--text, #2d3748);
    border-bottom-left-radius: 4px;
    font-family: 'Lora', Georgia, serif;
  }

  .hcm-user .hcm-bubble {
    background: var(--heading, #1a365d);
    color: white;
    border-bottom-right-radius: 4px;
    font-family: 'Lora', Georgia, serif;
  }

  .chat-hero-pills {
    padding: 0 20px 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hc-pill {
    padding: 9px 18px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid var(--border, #eee8dd);
    color: var(--heading, #1a365d);
    font-family: 'Bricolage Grotesque', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .hc-pill:hover {
    background: rgba(232, 130, 92, 0.08);
    border-color: var(--naranja, #e8825c);
    color: var(--naranja, #e8825c);
  }

  .chat-hero-input {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--border, #eee8dd);
    background: #faf8f4;
  }

  .chat-hero-input textarea {
    flex: 1;
    background: white;
    border: 1px solid var(--border, #eee8dd);
    border-radius: 12px;
    padding: 10px 14px;
    color: var(--text, #2d3748);
    font-size: 1rem;
    font-family: 'Lora', Georgia, serif;
    resize: none;
    outline: none;
    transition: border-color 0.2s;
  }

  .chat-hero-input textarea::placeholder {
    color: var(--gray, #718096);
  }

  .chat-hero-input textarea:focus {
    border-color: var(--naranja, #e8825c);
  }

  .hc-mic-btn, .hc-send-btn {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
  }

  .hc-mic-btn {
    background: #f0ebe3;
    border: 1px solid #d9d0c3;
    color: var(--heading, #1a365d);
  }

  .hc-mic-btn:hover {
    background: rgba(232, 130, 92, 0.15);
    border-color: var(--naranja, #e8825c);
    color: var(--naranja, #e8825c);
  }

  .hc-mic-btn.recording {
    background: rgba(239, 68, 68, 0.1) !important;
    border-color: rgba(239, 68, 68, 0.5) !important;
    color: #ef4444 !important;
    animation: mic-pulse 1.5s infinite ease-in-out;
  }

  @keyframes mic-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3); }
    50% { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); }
  }

  .hc-send-btn {
    background: var(--naranja, #e8825c);
    color: white;
  }

  .hc-send-btn:hover:not(:disabled) {
    background: #d4714e;
    transform: translateY(-1px);
  }

  .hc-send-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .hidden { display: none !important; }

  .typing-dot {
    animation: hc-typing 1.4s infinite ease-in-out;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes hc-typing {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }

  @media (max-width: 720px) {
    .chat-hero-section { padding: 0 16px 64px; }
    .chat-hero-tagline { font-size: 1rem; }
    .chat-hero-pills { gap: 6px; }
    .hc-pill { font-size: 0.72rem; padding: 7px 12px; }
  }
</style>

<script>
  const form = document.getElementById('hero-chat-form') as HTMLFormElement;
  const input = document.getElementById('hero-chat-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('hero-chat-send') as HTMLButtonElement;
  const messagesEl = document.getElementById('hero-chat-messages')!;
  const pillsEl = document.getElementById('hero-chat-pills')!;

  let messages: { role: string; content: string }[] = [];
  let isLoading = false;

  input.addEventListener('input', () => {
    sendBtn.disabled = input.value.trim().length === 0 || isLoading;
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 100) + 'px';
  });

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (!sendBtn.disabled) form.dispatchEvent(new Event('submit'));
    }
  });

  pillsEl.addEventListener('click', (e) => {
    const pill = (e.target as HTMLElement).closest('.hc-pill') as HTMLElement;
    if (pill) sendMessage(pill.dataset.msg || pill.textContent || '');
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text || isLoading) return;
    sendMessage(text);
  });

  async function sendMessage(text: string) {
    pillsEl.style.display = 'none';
    messages.push({ role: 'user', content: text });
    appendMessage('user', text);

    input.value = '';
    input.style.height = 'auto';
    sendBtn.disabled = true;
    isLoading = true;

    const typingEl = showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages, page_context: '/' }),
      });

      const data = await res.json();
      typingEl.remove();

      if (data.error) {
        appendMessage('assistant', 'Error — inténtalo de nuevo.');
        return;
      }

      const reply = data.content?.[0]?.text || data.response || 'No he podido responder.';
      messages.push({ role: 'assistant', content: reply });
      appendMessage('assistant', reply);
    } catch {
      typingEl.remove();
      appendMessage('assistant', 'Error de conexión.');
    } finally {
      isLoading = false;
      sendBtn.disabled = input.value.trim().length === 0;
    }
  }

  function appendMessage(role: string, text: string) {
    const wrapper = document.createElement('div');
    wrapper.className = role === 'user' ? 'hcm-user' : 'hcm-bot';

    if (role !== 'user') {
      const avatar = document.createElement('div');
      avatar.className = 'hcm-avatar';
      avatar.textContent = 'G';
      wrapper.appendChild(avatar);
    }

    const bubble = document.createElement('div');
    bubble.className = 'hcm-bubble';
    bubble.style.fontSize = '1rem';
    var formatted = text
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/\*\*([^*]+)\*\*/g, '<strong style="color:#e8825c">$1</strong>')
      .replace(/\n\n/g, '<br><br>')
      .replace(/\n/g, '<br>');
    bubble.innerHTML = formatted;
    wrapper.appendChild(bubble);
    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function showTyping(): HTMLElement {
    const wrapper = document.createElement('div');
    wrapper.className = 'hcm-bot';
    wrapper.innerHTML = `
      <div class="hcm-avatar">G</div>
      <div class="hcm-bubble" style="display:flex;gap:6px;align-items:center;padding:12px 16px">
        <span class="typing-dot" style="width:8px;height:8px;background:#e8825c;border-radius:50%;display:inline-block"></span>
        <span class="typing-dot" style="width:8px;height:8px;background:#e8825c;border-radius:50%;display:inline-block"></span>
        <span class="typing-dot" style="width:8px;height:8px;background:#e8825c;border-radius:50%;display:inline-block"></span>
      </div>`;
    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return wrapper;
  }

  // --- Voice input ---
  const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
  const micBtn = document.getElementById('hero-chat-mic') as HTMLButtonElement;
  const micSvg = '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-14 0m7 7v4m-3 0h6m-3-11V3a3 3 0 00-6 0v8a3 3 0 006 0z" /></svg>';
  const stopSvg = '<svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><rect x="6" y="6" width="12" height="12" rx="2" /></svg>';

  if (SpeechRecognition && micBtn) {
    micBtn.classList.remove('hidden');
    const rec = new SpeechRecognition();
    rec.lang = 'es-ES'; rec.interimResults = true; rec.continuous = false;
    let isRec = false; let ft = '';

    micBtn.addEventListener('click', () => { isRec ? rec.stop() : (ft='', rec.start()); });
    rec.addEventListener('start', () => { isRec=true; micBtn.classList.add('recording'); micBtn.innerHTML=stopSvg; input.placeholder='Escuchando...'; });
    rec.addEventListener('result', (e: any) => { let im=''; ft=''; for(let i=0;i<e.results.length;i++){e.results[i].isFinal?ft+=e.results[i][0].transcript:im+=e.results[i][0].transcript;} input.value=ft||im; input.dispatchEvent(new Event('input')); });
    rec.addEventListener('end', () => { isRec=false; micBtn.classList.remove('recording'); micBtn.innerHTML=micSvg; input.placeholder='Escríbeme algo...'; if(ft.trim()){input.value=ft.trim();input.dispatchEvent(new Event('input'));input.focus();} });
    rec.addEventListener('error', () => { isRec=false; micBtn.classList.remove('recording'); micBtn.innerHTML=micSvg; input.placeholder='Escríbeme algo...'; });
  }
</script>
