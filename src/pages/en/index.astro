---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Lightbox from '../../components/Lightbox.astro';
import PostStatsLoader from '../../components/PostStatsLoader.astro';
import { SITE_TITLE } from '../../consts';
import { useTranslations } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);
const SITE_DESCRIPTION_EN = 'A 72-year-old traveller discovering the last continent';

// Use EN posts if available, fallback to ES
let posts = (await getCollection('blogEn')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
if (posts.length === 0) {
	posts = (await getCollection('blogEs')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
}
const featuredPost = posts[0];
const gridPosts = posts.slice(1, 4);

function getReadingTime(body: string | undefined): number {
	return body ? Math.max(1, Math.ceil(body.split(/\s+/).length / 200)) : 5;
}

const tagStyles: Record<string, { background: string; color: string }> = {
	'📙 Memoria': { background: '#1a365d', color: 'white' },
	'🔥 Ahora': { background: '#e8825c', color: 'white' },
	'🔮 Horizonte': { background: 'linear-gradient(135deg, #1a365d, #e8825c)', color: 'white' },
	'🛠️ Taller': { background: '#a0aec0', color: 'white' },
	'😂 Anécdota': { background: '#fbd38d', color: '#2d3748' },
	'🎿 Vida': { background: '#48bb78', color: 'white' },
	'⭐ Reseña': { background: '#d69e2e', color: 'white' },
	'🧠 Proceso': { background: '#319795', color: 'white' },
	'🧠 Process': { background: '#319795', color: 'white' },
	'🌍 Reflexión': { background: '#5a67d8', color: 'white' },
	'🔧 Herramientas': { background: '#718096', color: 'white' },
};

const stats = [
	{ value: 72, label: t('home.years') as string },
	{ value: 42, label: t('home.sellingTrips') as string },
	{ value: 95, label: t('home.finalGrade') as string },
	{ value: 0, label: t('home.itEmployees') as string },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION_EN} lang={lang} />
	</head>
	<body>
		<Header lang={lang} />
		<main>
			<!-- Hero -->
			<section class="hero">
				<img
					src="/images/odisea-landscape.webp"
					alt="Giora Gilead: The Rewired Odyssey - complete infographic"
					class="hero-img zoomable"
					loading="eager"
				/>
				<p class="hero-caption">{t('home.heroCaption') as string}</p>
			</section>

			<!-- Stats -->
			<section class="stats-grid">
				{stats.map((s) => (
					<div class="stat-card">
						<span class="stat-number" data-target={s.value}>{s.value}</span>
						<span class="stat-label">{s.label}</span>
					</div>
				))}
			</section>

			<!-- Posts grid -->
			<section class="posts-section">
				<h2 class="section-title">{t('home.latestStories') as string}</h2>

				{featuredPost && (
					<a href={`/en/blog/${featuredPost.id}/`} class="featured-card" data-slug={featuredPost.id}>
						<div class="featured-thumb">
							<img src={`/og/${featuredPost.id}.png`} alt="" loading="lazy" />
						</div>
						<div class="featured-content">
							{featuredPost.data.tags && (
								<div class="post-tags">
									{featuredPost.data.tags.map((tag: string) => {
										const style = tagStyles[tag] || { background: '#a0aec0', color: 'white' };
										return (
											<span class="tag" style={`background: ${style.background}; color: ${style.color};`}>
												{tag}
											</span>
										);
									})}
								</div>
							)}
							<h3 class="featured-title">{featuredPost.data.title}</h3>
							<p class="featured-excerpt">{featuredPost.data.description}</p>
							<div class="post-meta">
								<FormattedDate date={featuredPost.data.pubDate} lang={lang} />
								<span class="post-reading">&middot; {getReadingTime(featuredPost.body)} {t('blog.minRead') as string}</span>
							</div>
							<span class="post-link">{t('blog.read') as string} &rarr;</span>
						</div>
					</a>
				)}

				<div class="posts-grid">
					{gridPosts.map((post) => (
						<a href={`/en/blog/${post.id}/`} class="grid-card" data-slug={post.id}>
							<div class="grid-thumb">
								<img src={`/og/${post.id}.png`} alt="" loading="lazy" />
							</div>
							<div class="grid-content">
								{post.data.tags && (
									<div class="post-tags">
										{post.data.tags.slice(0, 2).map((tag: string) => {
											const style = tagStyles[tag] || { background: '#a0aec0', color: 'white' };
											return (
												<span class="tag" style={`background: ${style.background}; color: ${style.color};`}>
													{tag}
												</span>
											);
										})}
									</div>
								)}
								<h3 class="grid-title">{post.data.title}</h3>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} lang={lang} />
									<span class="post-reading">&middot; {getReadingTime(post.body)} {t('blog.minRead') as string}</span>
								</div>
							</div>
						</a>
					))}
				</div>

				<div class="view-all">
					<a href="/en/blog/" class="btn-secondary">{t('home.viewAll') as string}</a>
				</div>
			</section>

			<!-- Quote -->
			<section class="quote-section">
				<blockquote>
					<p>{t('home.quote') as string}</p>
					<footer class="quote-attribution">{t('home.quoteAttribution') as string}</footer>
				</blockquote>
			</section>

			<!-- CTA -->
			<section class="cta-section">
				<p class="cta-text">{t('home.cta') as string}</p>
				<a href="/en/blog/the-night-of-the-gin-tonic-and-the-prompt/" class="btn-primary">{t('home.ctaButton') as string}</a>
			</section>
		</main>
		<Footer lang={lang} />
		<Lightbox />
		<PostStatsLoader />

		<script>
			// Counter animation on scroll
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const numbers = entry.target.querySelectorAll('.stat-number');
						numbers.forEach((el) => {
							const target = parseInt(el.getAttribute('data-target') || '0');
							if (target === 0) {
								el.textContent = '0';
								el.classList.add('counted');
								return;
							}
							let current = 0;
							const step = Math.max(1, Math.floor(target / 40));
							const interval = setInterval(() => {
								current += step;
								if (current >= target) {
									current = target;
									clearInterval(interval);
								}
								el.textContent = String(current);
							}, 30);
							el.classList.add('counted');
						});
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.3 });

			const statsGrid = document.querySelector('.stats-grid');
			if (statsGrid) observer.observe(statsGrid);
		</script>
	</body>
</html>
<style>
	main {
		padding-top: 2em;
	}

	/* Hero */
	.hero {
		text-align: center;
		margin-bottom: 2.5em;
	}
	.hero-img {
		width: 100%;
		max-width: 1200px;
		border-radius: 12px;
		box-shadow: 0 4px 20px rgba(26, 54, 93, 0.15);
	}
	.hero-caption {
		font-family: 'Bricolage Grotesque', sans-serif;
		color: var(--gray);
		font-size: 0.95em;
		margin-top: 0.8em;
		font-style: italic;
	}

	/* Stats */
	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1em;
		margin-bottom: 3em;
	}
	.stat-card {
		background: var(--heading);
		border-radius: 12px;
		padding: 1.5em 1em;
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		position: relative;
		overflow: hidden;
	}
	.stat-card::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--naranja);
		transform: scaleX(0);
		transition: transform 0.6s ease;
	}
	.stat-card:hover::after {
		transform: scaleX(1);
	}
	.stat-number {
		font-family: 'Bricolage Grotesque', sans-serif;
		font-size: 2.5em;
		font-weight: 700;
		color: var(--naranja);
		line-height: 1;
		transition: transform 0.3s ease;
	}
	.stat-card:hover .stat-number {
		transform: scale(1.1);
	}
	.stat-label {
		font-size: 0.8em;
		color: rgba(255, 255, 255, 0.85);
		line-height: 1.3;
	}

	/* Posts section */
	.posts-section {
		margin-bottom: 3em;
	}

	/* Featured card */
	.featured-card {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5em;
		text-decoration: none;
		padding: 1.2em;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: white;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
		margin-bottom: 1em;
	}
	.featured-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(26, 54, 93, 0.1);
		border-color: var(--naranja);
	}
	.featured-thumb {
		border-radius: 8px;
		overflow: hidden;
		aspect-ratio: 16/9;
	}
	.featured-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.featured-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-width: 0;
	}
	.featured-title {
		font-family: 'Bricolage Grotesque', sans-serif;
		color: var(--heading);
		font-size: 1.35em;
		margin: 0 0 0.5em;
		line-height: 1.3;
	}
	.featured-excerpt {
		color: var(--text);
		font-size: 0.9em;
		margin: 0 0 0.6em;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* Grid cards */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1em;
		margin-bottom: 1.5em;
	}
	.grid-card {
		text-decoration: none;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: white;
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}
	.grid-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(26, 54, 93, 0.1);
		border-color: var(--naranja);
	}
	.grid-thumb {
		aspect-ratio: 16/9;
		overflow: hidden;
	}
	.grid-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}
	.grid-card:hover .grid-thumb img {
		transform: scale(1.05);
	}
	.grid-content {
		padding: 0.8em 1em 1em;
	}
	.grid-title {
		font-family: 'Bricolage Grotesque', sans-serif;
		color: var(--heading);
		font-size: 0.95em;
		margin: 0 0 0.4em;
		line-height: 1.3;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* Shared post styles */
	.post-tags {
		display: flex;
		gap: 0.4em;
		margin-bottom: 0.5em;
		flex-wrap: wrap;
	}
	.post-tags .tag {
		border-radius: 999px;
		padding: 2px 10px;
		font-size: 0.72em;
		font-family: 'Bricolage Grotesque', sans-serif;
		white-space: nowrap;
	}
	.post-meta {
		font-size: 0.8em;
		color: var(--gray);
		margin-bottom: 0.5em;
	}
	.post-reading {
		margin-left: 0.2em;
	}
	.post-link {
		font-family: 'Bricolage Grotesque', sans-serif;
		color: var(--link);
		font-weight: 600;
		font-size: 0.9em;
	}
	.featured-card:hover .post-link {
		color: var(--naranja);
	}

	/* View all */
	.view-all {
		text-align: center;
	}

	/* Quote */
	.quote-section {
		margin-bottom: 3em;
	}
	.quote-attribution {
		display: block;
		font-size: 0.85em;
		color: var(--gray);
		margin-top: 0.8em;
		font-style: normal;
	}

	/* CTA */
	.cta-section {
		text-align: center;
		padding: 2.5em 1em;
		background: white;
		border-radius: 12px;
		border: 1px solid var(--border);
		margin-bottom: 2em;
	}
	.cta-text {
		font-family: 'Bricolage Grotesque', sans-serif;
		font-size: 1.4em;
		color: var(--heading);
		font-weight: 600;
		margin-bottom: 1em;
		line-height: 1.3;
	}

	@media (max-width: 720px) {
		.stats-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.stat-number {
			font-size: 2em;
		}
		.featured-card {
			grid-template-columns: 1fr;
		}
		.posts-grid {
			grid-template-columns: 1fr;
		}
		.cta-text {
			font-size: 1.2em;
		}
	}
</style>
