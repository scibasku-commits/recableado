---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Lightbox from '../components/Lightbox.astro';
import PostStatsLoader from '../components/PostStatsLoader.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import ChatHero from '../components/ChatHero.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'es' as const;
const t = useTranslations(lang);

const posts = (await getCollection('blogEs')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts[0];
const gridPosts = posts.slice(1, 4);

function getReadingTime(body: string | undefined): number {
	return body ? Math.max(1, Math.ceil(body.split(/\s+/).length / 200)) : 5;
}

const tagStyles: Record<string, { background: string; color: string }> = {
	'📙 Memoria': { background: '#1a365d', color: 'white' },
	'🔥 Ahora': { background: '#e8825c', color: 'white' },
	'🔮 Horizonte': { background: 'linear-gradient(135deg, #1a365d, #e8825c)', color: 'white' },
	'🛠️ Taller': { background: '#a0aec0', color: 'white' },
	'😂 Anécdota': { background: '#fbd38d', color: '#2d3748' },
	'🎿 Vida': { background: '#48bb78', color: 'white' },
	'⭐ Reseña': { background: '#d69e2e', color: 'white' },
	'🧠 Proceso': { background: '#319795', color: 'white' },
	'🧠 Process': { background: '#319795', color: 'white' },
	'🌍 Reflexión': { background: '#5a67d8', color: 'white' },
	'🔧 Herramientas': { background: '#718096', color: 'white' },
};

---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} lang={lang} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Space+Mono:wght@400;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body>
		<Header lang={lang} />
		<main>

			<!-- ══ BLOQUE 1: HERO OSCURO ══ -->
			<section class="blk-hero">
				<h1 class="hero-title">Recableado<br/>a los 73</h1>
				<p class="hero-sub">42 años vendiendo viajes. 5 continentes recorridos.<br/>Esquí en Japón, Estados Unidos y Canadá. Cruceros de vida a bordo en Polinesia, Indonesia y Mar Rojo.<br/>Y en 2025 descubrí el último continente: la inteligencia artificial.</p>
				<div class="blk-hero-wave"></div>
			</section>

			<!-- ══ BLOQUE 1.5: CHATBOT HERO ══ -->
			<ChatHero />

			<!-- ══ BLOQUE 2: CARDS CLARO ══ -->
			<section class="blk-cards">
				<div class="cards-grid">
					<div class="milestone-card">
						<div class="mc-icon">&#127864;</div>
						<div class="mc-date">Primavera 2025</div>
						<div class="mc-title">El Catalizador</div>
						<div class="mc-desc">La diabetes cancela los gin tonics. YouTube &rarr; IA.</div>
					</div>
					<div class="milestone-card">
						<div class="mc-icon">&#128218;</div>
						<div class="mc-date">Verano 2025</div>
						<div class="mc-title">La Inmersión</div>
						<div class="mc-desc">Curso DOMINA ChatGPT. Nota: 95/100. &laquo;Nativo digital de 30 años.&raquo;</div>
					</div>
					<div class="milestone-card">
						<div class="mc-icon">&#129302;</div>
						<div class="mc-date">Otoño 2025</div>
						<div class="mc-title">El Gran Hito</div>
						<div class="mc-desc">ClawdBot: Mac Mini 24/7 + 5 agentes IA trabajando mientras duerme.</div>
					</div>
					<div class="milestone-card">
						<div class="mc-icon">&#128640;</div>
						<div class="mc-date">2025–2026</div>
						<div class="mc-title">El Presente</div>
						<div class="mc-desc">recableado.blog &middot; 22 posts &middot; 2 idiomas &middot; 0 empleados IT &middot; 0 gin tonics</div>
					</div>
				</div>
				<div class="blk-cards-wave"></div>
			</section>

			<!-- ══ BLOQUE 3: STATS OSCURO ══ -->
			<section class="blk-stats">
				<div class="stats-board">
					<div class="stat-flip">
						<div class="stat-num" data-target="73">0</div>
						<div class="stat-lbl">{t('home.years') as string}</div>
					</div>
					<div class="stat-flip">
						<div class="stat-num" data-target="42">0</div>
						<div class="stat-lbl">{t('home.sellingTrips') as string}</div>
					</div>
					<div class="stat-flip">
						<div class="stat-num" data-target="95">0</div>
						<div class="stat-lbl">{t('home.finalGrade') as string}</div>
					</div>
					<div class="stat-flip">
						<div class="stat-num" data-target="0">0</div>
						<div class="stat-lbl">{t('home.itEmployees') as string}</div>
					</div>
				</div>
				<div class="blk-stats-wave"></div>
			</section>

			<!-- ══ BLOQUE 4: BOARDING PASS + TIMELINE CLARO ══ -->
			<section class="blk-itinerary">
				<div class="itinerary-label">El itinerario</div>

				<div class="boarding-pass">
					<div class="bp-main">
						<div class="bp-top-row">
							<div class="bp-label">Pasajero</div>
							<div class="bp-flight">SC-1954</div>
						</div>
						<div class="bp-name">Giora Gilead<br/>Elenberg</div>
						<div class="bp-route">
							<div class="bp-route-block">
								<div class="bp-route-label">Origen</div>
								<div class="bp-route-city">Marbella</div>
								<div class="bp-route-year">1954</div>
							</div>
							<div class="bp-arrow">&rarr;</div>
							<div class="bp-route-block">
								<div class="bp-route-label">Destino</div>
								<div class="bp-route-city">El Último</div>
								<div class="bp-route-year">Continente</div>
							</div>
						</div>
						<div class="bp-class">Clase: Premium sin artificios</div>
						<div class="bp-barcode" aria-hidden="true">
							<span></span><span></span><span></span><span></span><span></span><span></span>
							<span></span><span></span><span></span><span></span><span></span><span></span>
							<span></span><span></span><span></span><span></span><span></span><span></span>
							<span></span><span></span><span></span><span></span><span></span><span></span>
							<span></span><span></span><span></span><span></span><span></span><span></span>
						</div>
					</div>
					<div class="bp-perf"></div>
					<div class="bp-strip">
						<span class="bp-strip-text">Recableado &middot; Boarding Pass</span>
						<span class="bp-strip-seat">73A</span>
						<span class="bp-strip-seat-label">Seat</span>
					</div>
				</div>


			</section>

			<!-- ══ BLOQUE 5: POSTS ══ -->
			<section class="posts-section">
				<h2 class="section-title">{t('home.latestStories') as string}</h2>
				{featuredPost && (
					<a href={`/blog/${featuredPost.id}/`} class="featured-card" data-slug={featuredPost.id}>
						<div class="featured-thumb">
							<img src={`/og/${featuredPost.id}.png`} alt="" loading="lazy" />
						</div>
						<div class="featured-content">
							{featuredPost.data.tags && (
								<div class="post-tags">
									{featuredPost.data.tags.map((tag: string) => {
										const style = tagStyles[tag] || { background: '#a0aec0', color: 'white' };
										return <span class="tag" style={`background:${style.background};color:${style.color};`}>{tag}</span>;
									})}
								</div>
							)}
							<h3 class="featured-title">{featuredPost.data.title}</h3>
							<p class="featured-excerpt">{featuredPost.data.description}</p>
							<div class="post-meta">
								<FormattedDate date={featuredPost.data.pubDate} lang={lang} />
								<span class="post-reading">&middot; {getReadingTime(featuredPost.body)} {t('blog.minRead') as string}</span>
							</div>
							<span class="post-link">{t('blog.read') as string} &rarr;</span>
						</div>
					</a>
				)}
				<div class="posts-grid">
					{gridPosts.map((post) => (
						<a href={`/blog/${post.id}/`} class="grid-card" data-slug={post.id}>
							<div class="grid-thumb">
								<img src={`/og/${post.id}.png`} alt="" loading="lazy" />
							</div>
							<div class="grid-content">
								{post.data.tags && (
									<div class="post-tags">
										{post.data.tags.slice(0, 2).map((tag: string) => {
											const style = tagStyles[tag] || { background: '#a0aec0', color: 'white' };
											return <span class="tag" style={`background:${style.background};color:${style.color};`}>{tag}</span>;
										})}
									</div>
								)}
								<h3 class="grid-title">{post.data.title}</h3>
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} lang={lang} />
									<span class="post-reading">&middot; {getReadingTime(post.body)} {t('blog.minRead') as string}</span>
								</div>
							</div>
						</a>
					))}
				</div>
				<div class="view-all">
					<a href="/blog/" class="btn-secondary">{t('home.viewAll') as string}</a>
				</div>
			</section>

			<!-- ══ BLOQUE 6: QUOTE + CTA ══ -->
			<section class="quote-section">
				<blockquote>
					<p>{t('home.quote') as string}</p>
					<footer class="quote-attribution">&mdash; {(t('home.quoteAttribution') as string).replace('— ', '')}</footer>
				</blockquote>
			</section>
			<section class="cta-section">
				<p class="cta-text">{t('home.cta') as string}</p>
				<a href="/blog/la-noche-del-gin-tonic-y-el-prompt/" class="btn-primary">{t('home.ctaButton') as string}</a>
			</section>
		</main>
		<Footer lang={lang} />
		<Lightbox />
		<PostStatsLoader />

		<script>
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.querySelectorAll('.stat-num').forEach((el) => {
							const target = parseInt(el.getAttribute('data-target') || '0');
							if (target === 0) { el.textContent = '0'; return; }
							let current = 0;
							const step = Math.max(1, Math.floor(target / 40));
							const interval = setInterval(() => {
								current += step;
								if (current >= target) { current = target; clearInterval(interval); }
								el.textContent = String(current);
							}, 30);
						});
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.3 });
			const sb = document.querySelector('.stats-board');
			if (sb) observer.observe(sb);
		</script>
	</body>
</html>
<style is:global>
	/* ══════ BLOCK SYSTEM: alternating dark/light ══════ */

	/* ── BLOQUE 1: HERO OSCURO ── */
	.blk-hero {
		background: #0a0a1a;
		padding: 80px 28px 100px;
		text-align: center;
		position: relative;
		animation: fadeIn 0.8s ease;
		margin-left: calc(-50vw + 50%);
		margin-right: calc(-50vw + 50%);
		margin-top: -2em;
	}
	.hero-title {
		font-family: 'Playfair Display', serif;
		font-size: 4.5rem;
		font-weight: 700;
		color: #f0ede6;
		line-height: 1.0;
		margin: 0 0 20px;
	}
	.hero-sub {
		font-family: 'Inter', sans-serif;
		font-size: 1.15rem;
		color: #ff6b35;
		font-style: italic;
		margin: 0;
		letter-spacing: 0.5px;
	}
	.blk-hero-wave {
		position: absolute;
		bottom: 0; left: 0; right: 0;
		height: 40px;
		background: #f5f0e8;
		clip-path: ellipse(55% 100% at 50% 100%);
	}

	/* ── BLOQUE 2: CARDS CLARO ── */
	.blk-cards {
		background: #f5f0e8;
		padding: 48px 28px 80px;
		position: relative;
		margin-left: calc(-50vw + 50%);
		margin-right: calc(-50vw + 50%);
	}
	.cards-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
		max-width: 680px;
		margin: 0 auto;
	}
	.milestone-card {
		background: #fffdf7;
		border: 1px solid rgba(212,168,67,0.2);
		border-radius: 14px;
		padding: 24px;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.milestone-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(0,0,0,0.08);
	}
	.mc-icon { font-size: 2.4rem; margin-bottom: 10px; }
	.mc-date {
		font-family: 'Space Mono', monospace;
		font-size: 0.65rem; font-weight: 700; color: #ff6b35;
		letter-spacing: 2px; text-transform: uppercase; margin-bottom: 6px;
	}
	.mc-title {
		font-family: 'Playfair Display', serif;
		font-size: 1.15rem; font-weight: 700; color: #1a1a2e;
		margin-bottom: 8px; line-height: 1.2;
	}
	.mc-desc {
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem; color: #555; line-height: 1.55;
	}
	.blk-cards-wave {
		position: absolute;
		bottom: 0; left: 0; right: 0;
		height: 40px;
		background: #11111f;
		clip-path: ellipse(55% 100% at 50% 100%);
	}

	/* ── BLOQUE 3: STATS OSCURO ── */
	.blk-stats {
		background: #11111f;
		padding: 48px 28px 80px;
		position: relative;
		margin-left: calc(-50vw + 50%);
		margin-right: calc(-50vw + 50%);
	}
	.stats-board {
		display: grid; grid-template-columns: repeat(4, 1fr);
		gap: 12px; max-width: 680px; margin: 0 auto;
	}
	.stat-flip {
		background: #181828; border: 1px solid rgba(255,255,255,0.08);
		border-radius: 10px; padding: 22px 8px; text-align: center;
		position: relative; overflow: hidden;
	}
	.stat-flip::before {
		content: ''; position: absolute; top: 50%; left: 0; right: 0;
		height: 1px; background: rgba(255,255,255,0.06);
	}
	.stat-num {
		font-family: 'Playfair Display', serif;
		font-size: 2.8rem; font-weight: 700; color: #ff6b35;
		line-height: 1; position: relative; z-index: 1;
	}
	.stat-lbl {
		font-family: 'Space Mono', monospace;
		font-size: 0.6rem; color: #d4a843; letter-spacing: 1.5px;
		text-transform: uppercase; margin-top: 10px; position: relative; z-index: 1;
	}
	.blk-stats-wave {
		position: absolute;
		bottom: 0; left: 0; right: 0;
		height: 40px;
		background: #f5f0e8;
		clip-path: ellipse(55% 100% at 50% 100%);
	}

	/* ── BLOQUE 4: ITINERARY CLARO ── */
	.blk-itinerary {
		background: #f5f0e8;
		padding: 48px 28px 56px;
		margin-left: calc(-50vw + 50%);
		margin-right: calc(-50vw + 50%);
	}
	.blk-itinerary > * {
		max-width: 680px;
		margin-left: auto;
		margin-right: auto;
	}
	.itinerary-label {
		font-family: 'Space Mono', monospace;
		font-size: 0.7rem; font-weight: 700; color: #ff6b35;
		letter-spacing: 3px; text-transform: uppercase;
		margin-bottom: 20px;
	}

	/* Boarding pass — paper style */
	.boarding-pass {
		display: flex; background: #fffdf7;
		border: 1px solid #d4a843;
		border-radius: 16px; overflow: hidden; margin-bottom: 32px;
		box-shadow: 0 4px 16px rgba(0,0,0,0.06);
	}
	.bp-main { flex: 1; padding: 28px 32px 20px; }
	.bp-top-row {
		display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px;
	}
	.bp-label {
		font-family: 'Space Mono', monospace;
		font-size: 0.6rem; color: #8b8a99; letter-spacing: 3px; text-transform: uppercase;
	}
	.bp-flight {
		font-family: 'Space Mono', monospace;
		font-size: 0.7rem; font-weight: 700; color: #ff6b35; letter-spacing: 2px;
	}
	.bp-name {
		font-family: 'Playfair Display', serif;
		font-size: 2.2rem; font-weight: 700; color: #1a1a2e;
		line-height: 1.05; margin-bottom: 24px;
	}
	.bp-route { display: flex; gap: 36px; margin-bottom: 20px; align-items: flex-end; }
	.bp-route-label {
		font-family: 'Space Mono', monospace;
		font-size: 0.55rem; color: #8b8a99; letter-spacing: 3px;
		text-transform: uppercase; margin-bottom: 2px;
	}
	.bp-route-city {
		font-family: 'Space Mono', monospace;
		font-size: 1rem; font-weight: 700; color: #1a1a2e; letter-spacing: 1px;
	}
	.bp-route-year {
		font-family: 'Space Mono', monospace;
		font-size: 0.8rem; color: #d4a843;
	}
	.bp-arrow { font-size: 1.3rem; color: #ff6b35; padding-bottom: 4px; }
	.bp-class {
		font-family: 'Space Mono', monospace;
		font-size: 0.65rem; color: #d4a843; letter-spacing: 2px;
		text-transform: uppercase; padding-top: 14px;
		border-top: 1px solid rgba(0,0,0,0.08);
	}
	.bp-barcode {
		display: flex; gap: 2px; margin-top: 16px; height: 24px;
		align-items: flex-end; opacity: 0.15;
	}
	.bp-barcode span { display: block; width: 2px; background: #1a1a2e; border-radius: 1px; }
	.bp-barcode span:nth-child(odd) { height: 100%; }
	.bp-barcode span:nth-child(even) { height: 60%; }
	.bp-barcode span:nth-child(3n) { height: 80%; width: 3px; }
	.bp-barcode span:nth-child(5n) { height: 45%; }
	.bp-barcode span:nth-child(7n) { height: 90%; width: 1px; }
	.bp-perf {
		width: 1px; border-left: 2px dashed rgba(0,0,0,0.12); position: relative;
	}
	.bp-perf::before, .bp-perf::after {
		content: ''; position: absolute; left: -11px;
		width: 20px; height: 20px; background: #f5f0e8; border-radius: 50%;
	}
	.bp-perf::before { top: -10px; }
	.bp-perf::after { bottom: -10px; }
	.bp-strip {
		width: 72px; background: #f0ebe0; display: flex;
		flex-direction: column; align-items: center; justify-content: center; padding: 20px 0;
	}
	.bp-strip-text {
		font-family: 'Space Mono', monospace;
		writing-mode: vertical-rl; text-orientation: mixed;
		letter-spacing: 3px; font-size: 0.6rem; font-weight: 700;
		color: #ff6b35; text-transform: uppercase;
	}
	.bp-strip-seat {
		font-family: 'Space Mono', monospace;
		font-size: 1.4rem; font-weight: 700; color: #1a1a2e;
		margin-top: 12px; writing-mode: vertical-rl;
	}
	.bp-strip-seat-label {
		font-family: 'Space Mono', monospace;
		font-size: 0.5rem; color: #8b8a99; letter-spacing: 2px;
		writing-mode: vertical-rl; margin-top: 6px;
	}

	/* Timeline — light version */
	.timeline { position: relative; padding-left: 28px; }
	.timeline::before {
		content: ''; position: absolute; top: 6px; left: 5px; bottom: 6px;
		width: 2px; background: #ff6b35; opacity: 0.35;
	}
	.tl-item {
		position: relative; padding: 10px 12px 10px 0;
		border-radius: 8px; transition: background 0.2s ease;
	}
	.tl-item:hover { background: #fff3e8; }
	.tl-dot {
		position: absolute; left: -28px; top: 16px;
		width: 12px; height: 12px; border-radius: 50%;
		background: #f5f0e8; border: 2px solid #ff6b35;
	}
	.tl-last .tl-dot {
		background: #ff6b35; animation: pulse 2s ease infinite;
	}
	.tl-content { padding-left: 4px; }
	.tl-head { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
	.tl-year {
		font-family: 'Space Mono', monospace;
		font-size: 0.8rem; font-weight: 700; color: #ff6b35; letter-spacing: 1px;
	}
	.tl-place {
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem; font-weight: 600; color: #1a1a2e;
		text-transform: uppercase; letter-spacing: 0.5px;
	}
	.tl-desc {
		font-family: 'Inter', sans-serif;
		font-size: 0.82rem; color: #555; margin-top: 3px; line-height: 1.5;
	}

	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(16px); }
		to { opacity: 1; transform: translateY(0); }
	}
	@keyframes pulse {
		0%, 100% { box-shadow: 0 0 0 0 rgba(255,107,53,0.5); }
		50% { box-shadow: 0 0 0 8px rgba(255,107,53,0); }
	}

	/* ══════ POSTS (unchanged) ══════ */
	.posts-section { margin-bottom: 3em; }
	.featured-card {
		display: grid; grid-template-columns: 1fr 1fr; gap: 1.5em;
		text-decoration: none; padding: 1.2em; border-radius: 12px;
		border: 1px solid var(--border); background: white;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
		margin-bottom: 1em;
	}
	.featured-card:hover {
		transform: translateY(-2px); box-shadow: 0 4px 16px rgba(26,54,93,0.1);
		border-color: var(--naranja);
